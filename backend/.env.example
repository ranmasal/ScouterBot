# ScouterBot RAG Backend Configuration

# Server Settings
HOST=0.0.0.0
PORT=8000
DEBUG=false

# OpenAI Configuration (optional - for LLM-generated responses)
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-3.5-turbo

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector Store
VECTOR_STORE_PATH=./chroma_db
COLLECTION_NAME=scouting_docs

# Scoutbook Plus Authentication (optional)
SCOUTBOOK_USERNAME=your_scoutbook_username
SCOUTBOOK_PASSWORD=your_scoutbook_password

# Scraping Configuration
USE_CLOUDSCRAPER=true
USE_PLAYWRIGHT=false
REQUEST_TIMEOUT=30
REQUEST_DELAY=1.0

# Document Processing
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_DOCUMENTS=100

# CORS Origins
CORS_ORIGINS=chrome-extension://*

